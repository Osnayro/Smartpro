    function calculateLineDirection(line, param) {
        if (!line) return { dx: 1, dy: 0, dz: 0 };
        let pts = line._cachedPoints || line.points3D || line.points || [];
        if (!pts || pts.length < 2) return { dx: 1, dy: 0, dz: 0 };
        let lengths = [], totalLen = 0;
        for (let i = 0; i < pts.length - 1; i++) {
            let d = Math.hypot(pts[i+1].x - pts[i].x, pts[i+1].y - pts[i].y, pts[i+1].z - pts[i].z);
            lengths.push(d); totalLen += d;
        }
        if (totalLen === 0) return { dx: 1, dy: 0, dz: 0 };
        const targetLen = totalLen * param;
        let accum = 0, segIndex = 0;
        for (let i = 0; i < lengths.length; i++) {
            if (accum + lengths[i] >= targetLen || i === lengths.length - 1) { segIndex = i; break; }
            accum += lengths[i];
        }
        const p1 = pts[segIndex], p2 = pts[segIndex + 1];
        const dx = p2.x - p1.x, dy = p2.y - p1.y, dz = p2.z - p1.z;
        const len = Math.hypot(dx, dy, dz) || 1;
        return { dx: dx/len, dy: dy/len, dz: dz/len };
    }

    function getPerpendicularVector(dir) {
        let perp1 = { dx: -dir.dz, dy: 0, dz: dir.dx };
        let len1 = Math.hypot(perp1.dx, perp1.dy, perp1.dz);
        if (len1 < 0.1) perp1 = { dx: 1, dy: 0, dz: 0 };
        else { perp1.dx /= len1; perp1.dy /= len1; perp1.dz /= len1; }
        let perp2 = { dx: -dir.dy * dir.dx, dy: dir.dx * dir.dx + dir.dz * dir.dz, dz: -dir.dy * dir.dz };
        let len2 = Math.hypot(perp2.dx, perp2.dy, perp2.dz);
        if (len2 < 0.1) perp2 = { dx: 0, dy: 1, dz: 0 };
        else { perp2.dx /= len2; perp2.dy /= len2; perp2.dz /= len2; }
        return { horizontal: perp1, vertical: perp2 };
    }

    function getComponentDimension(tipo, diametro) {
        let lookupTipo = tipo;
        const tipoUpper = (tipo || '').toUpperCase();
        if (tipoUpper.includes('TEE_REDUCING')) lookupTipo = 'tee_reducing';
        else if (tipoUpper.includes('TEE')) lookupTipo = 'tee';
        else if (tipoUpper.includes('CROSS')) lookupTipo = 'cross';
        else if (tipoUpper.includes('ELBOW_90') || tipoUpper.includes('MITER_90')) lookupTipo = 'codo_90';
        else if (tipoUpper.includes('ELBOW_45') || tipoUpper.includes('ELBOW_22') || tipoUpper.includes('ELBOW_11')) lookupTipo = 'codo_45';
        else if (tipoUpper.includes('ELBOW_180')) lookupTipo = 'codo_90';
        else if (tipoUpper.includes('GATE_VALVE') || tipoUpper.includes('KNIFE_GATE')) lookupTipo = 'valvula_compuerta';
        else if (tipoUpper.includes('GLOBE_VALVE') || tipoUpper.includes('THREE_WAY') || tipoUpper.includes('FOUR_WAY')) lookupTipo = 'valvula_globo';
        else if (tipoUpper.includes('BALL_VALVE') || tipoUpper.includes('TRUNNION')) lookupTipo = 'valvula_bola';
        else if (tipoUpper.includes('BUTTERFLY_VALVE')) lookupTipo = 'valvula_mariposa';
        else if (tipoUpper.includes('REDUCER') || tipoUpper.includes('SWAGE')) lookupTipo = 'reduccion';
        else if (tipoUpper.includes('UNION')) lookupTipo = 'union_universal';
        else if (tipoUpper.includes('STUB_END')) lookupTipo = 'stub_end';
        else if (tipoUpper.includes('CAP') || tipoUpper.includes('TAPON')) lookupTipo = 'cap';
        else if (tipoUpper.includes('EXPANSION_JOINT') || tipoUpper.includes('BELLOWS')) lookupTipo = 'expansion_joint';
        else if (tipoUpper.includes('Y_STRAINER')) lookupTipo = 'y_strainer';
        else if (tipoUpper.includes('BASKET_STRAINER')) lookupTipo = 'basket_strainer';
        else if (tipoUpper.includes('STEAM_TRAP') && tipoUpper.includes('FLOAT')) lookupTipo = 'steam_trap_float';
        else if (tipoUpper.includes('STEAM_TRAP') && tipoUpper.includes('BUCKET')) lookupTipo = 'steam_trap_bucket';
        else if (tipoUpper.includes('STEAM_TRAP')) lookupTipo = 'steam_trap_thermo';
        else if (tipoUpper.includes('PRESSURE_GAUGE') || tipoUpper.includes('PRESSURE_TRANSMITTER') || tipoUpper.includes('DP_TRANSMITTER') || tipoUpper.includes('PRESSURE_SWITCH') || tipoUpper.includes('MANOMETRO')) lookupTipo = 'presion';
        else if (tipoUpper.includes('TEMPERATURE_GAUGE') || tipoUpper.includes('TEMPERATURE_TRANSMITTER') || tipoUpper.includes('TEMPERATURE_SWITCH') || tipoUpper.includes('TERMOMETRO')) lookupTipo = 'temperatura';
        else if (tipoUpper.includes('FLOW_METER') || tipoUpper.includes('VORTEX')) lookupTipo = 'flujo_mag';
        else if (tipoUpper.includes('CORIOLIS')) lookupTipo = 'flujo_mag';
        else if (tipoUpper.includes('ROTAMETER')) lookupTipo = 'rotametro';
        else if (tipoUpper.includes('SIGHT_GLASS') || tipoUpper.includes('VISOR')) lookupTipo = 'visor_flujo';
        else if (tipoUpper.includes('SILENCIADOR') || tipoUpper.includes('SILENCER')) lookupTipo = 'silenciador';
        else if (tipoUpper.includes('STATIC_MIXER')) lookupTipo = 'static_mixer';
        else if (tipoUpper.includes('PIG_LAUNCHER')) lookupTipo = 'pig_launcher';
        else if (tipoUpper.includes('FLANGE') || tipoUpper.includes('BRIDA')) {
            if (tipoUpper.includes('600')) lookupTipo = 'brida_espesor_600';
            else if (tipoUpper.includes('300')) lookupTipo = 'brida_espesor_300';
            else lookupTipo = 'brida_espesor_150';
        }
        const dims = dimensiones[lookupTipo];
        if (!dims) return 0;
        if (lookupTipo === 'reduccion') {
            if (typeof diametro === 'string' && dims[diametro] !== undefined) return dims[diametro];
            return dims["default"] || 120;
        }
        if (dims[diametro] !== undefined) return dims[diametro];
        const diameters = Object.keys(dims).map(Number).filter(k => !isNaN(k)).sort((a, b) => a - b);
        if (diameters.length === 0) return 0;
        if (typeof diametro === 'number') {
            if (diametro <= diameters[0]) return dims[diameters[0]];
            if (diametro >= diameters[diameters.length - 1]) return dims[diameters[diameters.length - 1]];
            for (let i = 0; i < diameters.length - 1; i++) {
                if (diametro >= diameters[i] && diametro <= diameters[i+1]) {
                    const d1 = diameters[i], d2 = diameters[i+1], v1 = dims[d1], v2 = dims[d2];
                    return Math.round(v1 + (v2 - v1) * (diametro - d1) / (d2 - d1));
                }
            }
        }
        return 0;
    }

    function getComponentOffset(tipo, diametro) {
        const dim = getComponentDimension(tipo, diametro) / 2;
        return dim > 0 ? dim : 50;
    }

    const baseGenerators = {
        TEE_EQUAL: (line, param, diametro, orientacionSugerida) => {
            const dir = calculateLineDirection(line, param);
            const perps = getPerpendicularVector(dir);
            const offset = getComponentOffset('TEE_EQUAL', diametro);
            let perp = orientacionSugerida || perps.vertical;
            if (orientacionSugerida) { const l = Math.hypot(perp.dx, perp.dy, perp.dz) || 1; perp = { dx: perp.dx/l, dy: perp.dy/l, dz: perp.dz/l }; }
            return [
                { id: 'RUN1', label: 'Entrada', relX: -dir.dx*offset, relY: -dir.dy*offset, relZ: -dir.dz*offset, orientacion: dir, diametro },
                { id: 'RUN2', label: 'Salida', relX: dir.dx*offset, relY: dir.dy*offset, relZ: dir.dz*offset, orientacion: dir, diametro },
                { id: 'BRANCH', label: 'Derivación', relX: perp.dx*offset, relY: perp.dy*offset, relZ: perp.dz*offset, orientacion: perp, diametro }
            ];
        },
        VALVE: (line, param, diametro) => {
            const dir = calculateLineDirection(line, param);
            const offset = getComponentOffset('VALVE', diametro);
            return [
                { id: 'IN', label: 'Entrada', relX: -dir.dx*offset, relY: -dir.dy*offset, relZ: -dir.dz*offset, orientacion: dir, diametro },
                { id: 'OUT', label: 'Salida', relX: dir.dx*offset, relY: dir.dy*offset, relZ: dir.dz*offset, orientacion: dir, diametro }
            ];
        },
        REDUCER: (line, param, diametro) => {
            const dir = calculateLineDirection(line, param);
            const offset = getComponentOffset('REDUCER', diametro);
            return [
                { id: 'IN', label: 'Entrada', relX: -dir.dx*offset, relY: -dir.dy*offset, relZ: -dir.dz*offset, orientacion: dir, diametro },
                { id: 'OUT', label: 'Salida', relX: dir.dx*offset, relY: dir.dy*offset, relZ: dir.dz*offset, orientacion: dir, diametro: diametro * 0.625 }
            ];
        }
    };

    function assignGenerators() {
        const teeEqualKeys = ['TEE_EQUAL_CS', 'TEE_EQUAL_PPR', 'TEE_EQUAL_HDPE', 'TEE_EQUAL_PVC', 'TEE_EQUAL_SS'];
        const teeReducingKeys = ['TEE_REDUCING_CS', 'TEE_REDUCING_PPR', 'TEE_REDUCING_PVC', 'TEE_REDUCING_HDPE', 'TEE_REDUCING_SS'];
        const crossKeys = ['CROSS_CS'];
        const lateralKeys = ['LATERAL_45_CS', 'TRUE_WYE_CS'];
        const oletKeys = ['WELDOLET_CS', 'SOCKOLET_CS_3000', 'THREADOLET_CS_3000', 'ELBOLET_CS'];
        for (const key of teeEqualKeys) { if (components[key] && !components[key].generarPuertos) components[key].generarPuertos = baseGenerators.TEE_EQUAL; }
        for (const key of teeReducingKeys) { if (components[key] && !components[key].generarPuertos) components[key].generarPuertos = baseGenerators.TEE_EQUAL; }
        for (const key of crossKeys) { if (components[key] && !components[key].generarPuertos) components[key].generarPuertos = baseGenerators.TEE_EQUAL; }
        for (const key of lateralKeys) { if (components[key] && !components[key].generarPuertos) components[key].generarPuertos = baseGenerators.TEE_EQUAL; }
        for (const key of oletKeys) { if (components[key] && !components[key].generarPuertos) components[key].generarPuertos = baseGenerators.TEE_EQUAL; }
        for (const [key, comp] of Object.entries(components)) {
            if (comp.generarPuertos) continue;
            const tipo = comp.tipo || '';
            if (tipo.includes('VALVE') || tipo.includes('CHECK') || tipo.includes('RELIEF') || tipo.includes('DRAIN') || tipo.includes('AIR_RELEASE') || tipo.includes('VACUUM') || tipo.includes('SAMPLE') || tipo.includes('ASEPTIC') || tipo.includes('NEEDLE') || tipo.includes('PINCH') || tipo.includes('CHOKE') || tipo.includes('CRYOGENIC') || tipo.includes('SOLENOID')) {
                comp.generarPuertos = baseGenerators.VALVE;
            } else if (tipo.includes('REDUCER') || tipo.includes('SWAGE')) {
                comp.generarPuertos = baseGenerators.REDUCER;
            }
        }
    }
    assignGenerators();

    // ================================================================
    // 6. ALIASES
    // ================================================================
    const _equipmentAliases = {
        'tanque_vertical': 'tanque_v', 'tanquevertical': 'tanque_v', 'tanque_horizontal': 'tanque_h', 'tanquehorizontal': 'tanque_h',
        'bomba_centrifuga': 'bomba', 'bombacentrifuga': 'bomba', 'bomba_z': 'bomba_z',
        'bomba_dosificadora': 'bomba_dosificacion', 'intercambiador_calor': 'intercambiador', 'intercambiador': 'intercambiador',
        'torre_destilacion': 'torre', 'torredestilacion': 'torre', 'compresor': 'compresor', 'separador': 'separador',
        'caldera': 'caldera', 'clarificador': 'clarificador', 'filtro_arena': 'filtro_arena', 'filtroarena': 'filtro_arena',
        'osmosis': 'osmosis', 'bomba_sumergible': 'bomba_sumergible', 'tanque_acero': 'tanque_acero', 'pasteurizador': 'pasteurizador',
        'homogeneizador': 'homogeneizador', 'plataforma': 'plataforma',
        'pump': 'bomba', 'tank': 'tanque_v', 'tk': 'tanque_v', 'p': 'bomba', 'e': 'intercambiador', 't': 'torre', 'r': 'reactor',
        'v': 'tanque_v', 'c': 'compresor', 'sep': 'separador', 'chiller': 'chiller', 'cooling_tower': 'torre_enfriamiento',
        'deaerator': 'desaireador', 'steam_generator': 'generador_vapor', 'ejector': 'eyector',
        'hydrocyclone': 'hidrociclon', 'sphere': 'tanque_almacenamiento_gas', 'water_tank': 'tanque_almacenamiento_agua',
        'accumulator': 'tanque_pulmon', 'steam_header': 'colector_vapor'
    };

    function resolveEquipmentAlias(tipo) {
        if (!tipo) return null;
        const key = tipo.toLowerCase().replace(/[\s-]+/g, '_');
        if (_equipmentAliases[key]) return _equipmentAliases[key];
        if (equipment[tipo]) return tipo;
        if (equipment[key]) return key;
        return null;
    }

    const _componentAliases = {
        'TE': 'TEE_EQUAL_CS', 'TR': 'TEE_REDUCING_CS', 'CR': 'CROSS_CS', 'EL': 'ELBOW_90_LR_CS', 'E4': 'ELBOW_45_CS',
        'GV': 'GATE_VALVE_CS_150', 'GL': 'GLOBE_VALVE_CS_150', 'VB': 'BUTTERFLY_VALVE_CS_150', 'BA': 'BALL_VALVE_CS_150',
        'CK': 'CHECK_VALVE_SWING_CS', 'DV': 'DIAPHRAGM_VALVE_PTFE', 'CV': 'CONTROL_VALVE_CS',
        'RC': 'CONCENTRIC_REDUCER_CS', 'RE': 'ECCENTRIC_REDUCER_CS', 'FL': 'WELD_NECK_FLANGE_150', 'FB': 'BLIND_FLANGE_150',
        'CA': 'CAP_CS', 'UN': 'UNION_CS_3000', 'NI': 'NIPLE_ACERO_3IN_150MM', 'BH': 'BULKHEAD_PE_3IN',
        'EJ': 'EXPANSION_JOINT_CS', 'YS': 'Y_STRAINER_CS', 'BS': 'BASKET_STRAINER',
        'ST': 'STEAM_TRAP_THERMODYNAMIC', 'PG': 'PRESSURE_GAUGE', 'TG': 'TEMPERATURE_GAUGE', 'FM': 'FLOW_METER_MAG',
        'PT': 'PRESSURE_TRANSMITTER', 'LT': 'LEVEL_TRANSMITTER', 'TT': 'TEMPERATURE_TRANSMITTER',
        'RO': 'ROTAMETER', 'SG': 'SIGHT_GLASS', 'LS': 'LEVEL_SWITCH_RANA', 'SH': 'PIPE_SHOE', 'UB': 'U_BOLT',
        'GD': 'GUIDE', 'AN': 'ANCHOR', 'HG': 'HANGER', 'PC': 'PIPE_CLAMP', 'CM': 'CAMLOCK_MALE', 'CF': 'CAMLOCK_FEMALE',
        'QC': 'QUICK_CONNECT', 'HO': 'FLEXIBLE_HOSE', 'HM': 'METALLIC_HOSE', 'HP': 'PTFE_HOSE',
        'SI': 'SILENCER', 'FA': 'FLAME_ARRESTER', 'DP': 'DP_TRANSMITTER', 'LR': 'RADAR_LEVEL',
        'FV': 'VORTEX_FLOW_METER', 'GD': 'GAS_DETECTOR', 'FD': 'FLAME_DETECTOR', 'HS': 'H2S_DETECTOR',
        'VI': 'VIBRATION_SENSOR', 'POS': 'POSITIONER', 'SOL': 'SOLENOID_VALVE', 'PS': 'PRESSURE_SWITCH',
        'FS': 'FLOW_SWITCH', 'LV': 'LEVEL_SWITCH_VIBRATORY', 'ML': 'MAGNETIC_LEVEL_INDICATOR',
        'TU': 'TURBIDITY_METER', 'CL': 'CHLORINE_ANALYZER', 'O2': 'OXYGEN_ANALYZER',
        'WO': 'WELDOLET_CS', 'SO': 'SOCKOLET_CS_3000', 'TO': 'THREADOLET_CS_3000', 'EO': 'ELBOLET_CS',
        'LT': 'LATERAL_45_CS', 'WY': 'TRUE_WYE_CS', 'SC': 'SWAGE_CONC_CS', 'SE': 'SWAGE_ECC_CS',
        'BA': 'BELLOWS_AXIAL_CS', 'BU': 'BELLOWS_UNIVERSAL_CS', 'RD': 'RUPTURE_DISC',
        'PL': 'PIPELINE_PIG_LAUNCHER', 'UV': 'UV_STERILIZER', 'OZ': 'OZONE_GENERATOR',
        'codo': 'ELBOW_90_LR_CS', 'codo90': 'ELBOW_90_LR_CS', 'codo45': 'ELBOW_45_CS', 'tee': 'TEE_EQUAL_CS',
        'valvula': 'GATE_VALVE_CS_150', 'brida': 'WELD_NECK_FLANGE_150', 'reduccion': 'CONCENTRIC_REDUCER_CS',
        'manometro': 'PRESSURE_GAUGE', 'termometro': 'TEMPERATURE_GAUGE', 'caudalimetro': 'FLOW_METER_MAG',
        'filtro_y': 'Y_STRAINER_CS', 'trampa_vapor': 'STEAM_TRAP_THERMODYNAMIC',
        'union': 'UNION_CS_3000', 'niple': 'NIPLE_ACERO_3IN_150MM', 'tapon': 'CAP_CS',
        'valvula_seguridad': 'SAFETY_VALVE_SS', 'valvula_alivio': 'PRESSURE_RELIEF_VALVE',
        'transmisor_presion': 'PRESSURE_TRANSMITTER', 'detector_gas': 'GAS_DETECTOR',
        'sensor_vibracion': 'VIBRATION_SENSOR', 'posicionador': 'POSITIONER'
    };

    function resolveComponentAlias(compName) {
        if (!compName) return null;
        const key = compName.toLowerCase().replace(/[\s-]+/g, '_');
        if (_componentAliases[key]) { const r = _componentAliases[key]; if (components[r]) return r; }
        if (components[compName]) return compName;
        const upper = compName.toUpperCase();
        for (const compKey of Object.keys(components)) {
            if (compKey.toUpperCase() === upper) return compKey;
        }
        return null;
    }

    // ================================================================
    // 7. FUNCIONES DE CREACIÓN Y VALIDACIÓN
    // ================================================================
    function validateSpec(specId) {
        if (!specId) return { valid: false, message: 'Spec no especificada' };
        if (specs[specId]) return { valid: true, spec: specs[specId], id: specId };
        return { valid: false, message: `Spec "${specId}" no encontrada`, suggestions: Object.keys(specs).slice(0, 5) };
    }

    function createLine(tag, diameter, material, spec, points, options = {}) {
        const specDef = specs[spec] || specs['PPR_PN12_5'];
        const pts = points.map(p => ({ x: p.x || p[0] || 0, y: p.y || p[1] || 0, z: p.z || p[2] || 0 }));
        const line = {
            tag: tag || `L-${Date.now().toString(36).slice(-4)}`,
            diameter: diameter || 4,
            material: material || specDef.material || 'PPR',
            spec: spec || 'PPR_PN12_5',
            _cachedPoints: pts, points3D: pts, waypoints: pts.slice(1, -1),
            components: options.components || [], puertos: options.puertos || [],
            origin: options.origin || null, destination: options.destination || null,
            isoColor: options.color || specDef.color || 0x7c3aed
        };
        if (pts.length >= 2) {
            const dirStart = { dx: pts[1].x - pts[0].x, dy: pts[1].y - pts[0].y, dz: pts[1].z - pts[0].z };
            const lenStart = Math.hypot(dirStart.dx, dirStart.dy, dirStart.dz) || 1;
            if (!line.puertos.find(p => p.id === 'START')) line.puertos.push({ id: 'START', label: 'Inicio', relX: 0, relY: 0, relZ: 0, orientacion: { dx: dirStart.dx/lenStart, dy: dirStart.dy/lenStart, dz: dirStart.dz/lenStart }, diametro: diameter, status: 'open' });
            const n = pts.length;
            const dirEnd = { dx: pts[n-1].x - pts[n-2].x, dy: pts[n-1].y - pts[n-2].y, dz: pts[n-1].z - pts[n-2].z };
            const lenEnd = Math.hypot(dirEnd.dx, dirEnd.dy, dirEnd.dz) || 1;
            if (!line.puertos.find(p => p.id === 'END')) line.puertos.push({ id: 'END', label: 'Fin', relX: 0, relY: 0, relZ: 0, orientacion: { dx: dirEnd.dx/lenEnd, dy: dirEnd.dy/lenEnd, dz: dirEnd.dz/lenEnd }, diametro: diameter, status: 'open' });
        }
        return line;
    }

    function createEquipment(tipo, tag, x, y, z, opciones = {}) {
        const resolved = resolveEquipmentAlias(tipo);
        if (!resolved) return null;
        const def = equipment[resolved];
        if (!def) return null;
        let defaultSpec = 'ACERO_150_RF', defaultMaterial = 'CS';
        const material = (opciones.material || '').toUpperCase();
        if (material.includes('PPR')) { defaultSpec = 'PPR_PN12_5'; defaultMaterial = 'PPR'; }
        else if (material.includes('PE') || material.includes('HDPE')) { defaultSpec = 'HDPE_PE100'; defaultMaterial = 'HDPE'; }
        else if (material.includes('PVC')) { defaultSpec = 'PVC_SCH80'; defaultMaterial = 'PVC'; }
        else if (material.includes('CPVC')) { defaultSpec = 'CPVC_SCH80'; defaultMaterial = 'CPVC'; }
        else if (material.includes('INOX') || material.includes('STAINLESS')) { defaultSpec = 'SS_150_RF'; defaultMaterial = 'SS'; }
        else if (material.includes('DUPLEX')) { defaultSpec = 'DUPLEX_150_RF'; defaultMaterial = 'DUPLEX'; }
        else if (material.includes('HASTELLOY')) { defaultSpec = 'HASTELLOY_150_RF'; defaultMaterial = 'HASTELLOY'; }
        else if (material.includes('INCONEL')) { defaultSpec = 'INCONEL_150_RF'; defaultMaterial = 'INCONEL'; }
        else if (material.includes('TITANIO')) { defaultSpec = 'TITANIUM_150_RF'; defaultMaterial = 'TI'; }
        else if (material.includes('ALUMINIO')) { defaultSpec = 'ALUMINUM_150_RF'; defaultMaterial = 'AL'; }
        else if (material.includes('BRONCE')) { defaultSpec = 'BRONZE_150_RF'; defaultMaterial = 'BRONZE'; }
        else if (material.includes('HIERRO') || material.includes('FUNDIDO')) { defaultSpec = 'CAST_IRON_125'; defaultMaterial = 'CI'; }
        else if (material.includes('FRP')) { defaultSpec = 'FRP'; defaultMaterial = 'FRP'; }
        else if (material.includes('CONCRETO') || material.includes('HORMIGON')) { defaultSpec = 'HORMIGON_ESTRUCTURAL'; defaultMaterial = 'CONCRETO'; }
        const specValidation = validateSpec(opciones.spec || defaultSpec);
        const finalSpec = specValidation.valid ? (opciones.spec || defaultSpec) : defaultSpec;
        let base = {
            tag, tipo: resolved, posX: x, posY: y, posZ: z,
            diametro: opciones.diametro || 1000, altura: opciones.altura || 1500,
            material: opciones.material || defaultMaterial, spec: finalSpec,
            largo: opciones.largo || 1000, ancho: opciones.ancho || 1000
        };
        if (resolved === 'plataforma') {
            base.largo = opciones.largo || 6000; base.ancho = opciones.ancho || 3000;
            base.altura = opciones.altura || 400;
            base.baranda = opciones.baranda !== undefined ? opciones.baranda : true;
            base.escalera = opciones.escalera !== undefined ? opciones.escalera : true;
        }
        base.puertos = def.generarPuertos(base).map(p => ({ ...p, spec: base.spec, status: 'open', diametro: p.diametro || 3 }));
        return base;
    }

    // ================================================================
    // 8. API PÚBLICA
    // ================================================================
    return {
        getSpecs: () => specs,
        getSpec: (id) => specs[id] || null,
        validateSpec,
        listSpecs: () => Object.keys(specs),
        getEquipment: (tipo) => { const r = resolveEquipmentAlias(tipo); return r ? equipment[r] : null; },
        listEquipmentTypes: () => Object.keys(equipment),
        resolveEquipmentAlias,
        createEquipment,
        getComponent: (id) => components[id] || (() => { const r = resolveComponentAlias(id); return r ? components[r] : null; })(),
        listComponentTypes: () => Object.keys(components),
        resolveComponentAlias,
        getComponentDimension,
        createLine,
        createComponent: (compId, opciones = {}) => {
            const def = components[compId] || null;
            if (!def) { const r = resolveComponentAlias(compId); if (r) return { ...components[r], ...opciones, id: r }; return null; }
            return { ...def, ...opciones, id: compId };
        }
    };
})();

